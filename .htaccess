# ----------------------------------------------------------------------
# .htaccess RECOMENDADO POR SITEGROUND (MODO DEPURACIÓN)
# ----------------------------------------------------------------------

# Asegurar que el servidor busque nuestro index.html
DirectoryIndex index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. EXCLUIR VALIDACIONES SSL Y ACTIVOS ESTÁTICOS
    # Evita que las reglas de redirección afecten a procesos críticos o archivos de diseño
    RewriteCond %{REQUEST_URI} !^/\.well-known/ [NC]
    RewriteCond %{REQUEST_URI} !\.(css|js|jpg|jpeg|png|gif|svg|webp|ico)$ [NC]

    # 2. FORZAR NO-WWW (Canónico: mundogeneticocolombia.com)
    # Usamos R=302 (temporal) para evitar bloqueos por caché del navegador durante las pruebas.
    RewriteCond %{HTTP_HOST} ^www\.mundogeneticocolombia\.com$ [NC]
    RewriteRule ^ https://mundogeneticocolombia.com%{REQUEST_URI} [L,R=302]

    # 3. FORZAR HTTPS (DELEGADO A SITE TOOLS)
    # Nota: No añadimos la regla de HTTPS aquí porque el panel de SiteGround ya tiene
    # el switch "Forzar HTTPS" activado. Tener ambos produce el bucle infinito.

</IfModule>

# 4. SEGURIDAD BÁSICA
Options -Indexes

# 5. PREVENIR ACCESO A ARCHIVOS SENSIBLES
<FilesMatch "\.(env|log|md|bak|sql|config|git)$">
    Order allow,deny
    Deny from all
</FilesMatch>
