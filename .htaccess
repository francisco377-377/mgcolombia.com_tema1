# ----------------------------------------------------------------------
# REGLAS DE SEGURIDAD Y RENDIMIENTO (MUNDO GENÉTICO) - SIMPLIFICADO POR EMERGENCIA
# ----------------------------------------------------------------------

# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     
#     # 1. FORZAR HTTPS (Certificado SSL)
#     # RewriteCond %{HTTPS} off
#     # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# 
#     # 2. REDIRIGIR WWW A SIN WWW
#     # RewriteCond %{HTTP_HOST} ^www\.mundogeneticocolombia\.com$ [NC]
#     # RewriteRule ^(.*)$ https://mundogeneticocolombia.com/$1 [L,R=301]
# </IfModule>

# ----------------------------------------------------------------------
# ARCHIVO PRINCIPAL POR DEFECTO
# ----------------------------------------------------------------------
DirectoryIndex index.html index.php

# ----------------------------------------------------------------------
# SEGURIDAD DE ENCABEZADOS - COMENTADO TEMPORALMENTE PARA DEBUG
# ----------------------------------------------------------------------
# <IfModule mod_headers.c>
#     Header always set X-Frame-Options "SAMEORIGIN"
#     Header always set X-XSS-Protection "1; mode=block"
#     Header always set X-Content-Type-Options "nosniff"
#     Header always set Referrer-Policy "strict-origin-when-cross-origin"
# </IfModule>

# ----------------------------------------------------------------------
# PROTECCIÓN DE DIRECTORIOS Y ARCHIVOS
# ----------------------------------------------------------------------
Options -Indexes

# Bloquear archivos sensibles
<FilesMatch "\.(env|log|md|bak|sql|config|git)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ----------------------------------------------------------------------
# OPTIMIZACIÓN - COMENTADO TEMPORALMENTE PARA DEBUG
# ----------------------------------------------------------------------
# <IfModule mod_deflate.c>
#     AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript image/svg+xml
# </IfModule>

